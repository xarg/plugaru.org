<footer id="footer">
    <div id="search-form-wrap">
        <%- search_form({text: 'Google Search', button: 'Search'}) %>
    </div>
    <nav id="main-nav">
        <% for (var i in theme.menu){ %>
        <a class="main-nav-link" href="<%- url_for(theme.menu[i]) %>"><%= i %></a>
        <% } %>
    </nav>
    <% if (theme.rss){ %>
    <nav id="sub-nav">
        <a id="nav-rss-link" href="<%- url_for(theme.rss) %>"><%= __('rss_feed') %></a>
    </nav>
    <% } %>
    <div class="outer">
        <div id="footer-info" class="inner">&copy; <%= date(new Date(), 'YYYY') %> <%= config.author || config.title %>
            <br></div>
    </div>
</footer>

<%- partial('google-analytics') %>
